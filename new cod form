import React, { useState, useEffect } from 'react';
import { 
  Package, 
  Truck, 
  User, 
  Phone, 
  MapPin, 
  Building, 
  CheckCircle, 
  X, 
  ShoppingBag, 
  AlertCircle,
  ChevronRight,
  Loader2
} from 'lucide-react';

// --- CONFIGURATION ---
const CURRENCY = 'dh';
const SHOP_NAME = 'My Fashion Store';

const App = () => {
  const [isOpen, setIsOpen] = useState(false);
  const [isLoading, setIsLoading] = useState(false);
  const [orderStatus, setOrderStatus] = useState('idle'); // idle, loading, success, error
  
  // Mock Shopify Product Data (In a real app, this would come from your Liquid template or Storefront API)
  const product = {
    id: "gid://shopify/Product/123456789",
    title: "طقم ملابس للأولاد مكون من 3 قطع",
    variant: "أزرق / 18-24 شهراً",
    price: 287.90,
    image: "https://placehold.co/100x100/e2e8f0/475569?text=Product",
    inventory_quantity: 5, // Simulated inventory check
    sku: "SURFLO-KIDS-001"
  };

  // Form State
  const [formData, setFormData] = useState({
    name: '',
    phone: '',
    address: '',
    city: '',
  });

  const [errors, setErrors] = useState({});

  const validate = () => {
    let newErrors = {};
    if (!formData.name) newErrors.name = 'الاسم مطلوب';
    if (!formData.phone) newErrors.phone = 'رقم الهاتف مطلوب';
    if (!formData.address) newErrors.address = 'العنوان مطلوب';
    if (!formData.city) newErrors.city = 'المدينة مطلوبة';
    setErrors(newErrors);
    return Object.keys(newErrors).length === 0;
  };

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
    if (errors[name]) setErrors(prev => ({ ...prev, [name]: '' }));
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (!validate()) return;
    
    // Check Inventory one last time before submitting
    if (product.inventory_quantity <= 0) {
      setOrderStatus('out-of-stock');
      return;
    }

    setIsLoading(true);
    setOrderStatus('loading');

    // --- SHOPIFY INTEGRATION LOGIC ---
    // In a real Shopify app, you would POST this to an App Proxy or a custom backend
    // which then uses the Shopify Admin API to create a Draft Order.
    try {
      console.log('Creating Shopify Draft Order...', {
        line_items: [{ title: product.title, variant_id: product.id, quantity: 1, price: product.price }],
        customer: { first_name: formData.name, phone: formData.phone },
        shipping_address: { address1: formData.address, city: formData.city, country: 'Morocco' },
        tags: ["COD-Quick-Order"],
        note: "Order placed via Quick COD Form"
      });

      // Simulate API Call delay
      await new Promise(resolve => setTimeout(resolve, 2000));
      
      setOrderStatus('success');
    } catch (err) {
      setOrderStatus('error');
    } finally {
      setIsLoading(false);
    }
  };

  const resetForm = () => {
    setIsOpen(false);
    setOrderStatus('idle');
    setFormData({ name: '', phone: '', address: '', city: '' });
  };

  return (
    <div className="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-4 font-sans rtl" dir="rtl">
      
      {/* 1. MOCK PRODUCT PAGE BUTTON */}
      <div className="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 max-w-md w-full">
        <div className="flex items-center gap-4 mb-6">
          <img src={product.image} alt="product" className="w-20 h-20 rounded-lg object-cover" />
          <div>
            <h3 className="font-bold text-gray-800">{product.title}</h3>
            <p className="text-sm text-gray-500">{product.variant}</p>
            <p className="text-blue-600 font-bold mt-1">{product.price.toFixed(2)} {CURRENCY}</p>
          </div>
        </div>

        <button className="w-full bg-black text-white py-4 rounded-xl font-bold mb-3 hover:bg-gray-800 transition-colors flex items-center justify-center gap-2">
          <ShoppingBag size={20} />
          أضف إلى السلة
        </button>

        <button 
          onClick={() => setIsOpen(true)}
          className="w-full bg-emerald-600 text-white py-4 rounded-xl font-bold hover:bg-emerald-700 transition-all flex items-center justify-center gap-2 shadow-lg shadow-emerald-100"
        >
          <Truck size={20} />
          اطلب الآن والدفع عند الاستلام
        </button>
        
        <p className="text-center text-xs text-gray-400 mt-4">
          {product.inventory_quantity > 0 ? `متوفر فقط ${product.inventory_quantity} قطع في المخزن` : 'خارج المخزن'}
        </p>
      </div>

      {/* 2. THE COD POPUP MODAL */}
      {isOpen && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
          <div className="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden relative animate-in fade-in zoom-in duration-200">
            
            {/* Close Button */}
            <button 
              onClick={resetForm}
              className="absolute top-4 left-4 p-2 rounded-full hover:bg-gray-100 transition-colors z-10"
            >
              <X size={20} className="text-gray-400" />
            </button>

            {orderStatus === 'success' ? (
              <SuccessState onDone={resetForm} />
            ) : (
              <div className="flex flex-col h-full max-h-[90vh] overflow-y-auto">
                {/* Header / Product Summary */}
                <div className="p-5 border-b border-gray-100 bg-gray-50/50">
                  <div className="flex gap-4">
                    <div className="relative">
                      <img src={product.image} className="w-16 h-16 rounded-xl border bg-white" alt="order" />
                      <span className="absolute -top-2 -right-2 bg-gray-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold">1</span>
                    </div>
                    <div className="flex-1">
                      <h4 className="font-bold text-gray-800 text-sm leading-snug truncate max-w-[250px]">
                        {product.title}
                      </h4>
                      <p className="text-xs text-gray-500 mt-1">{product.variant}</p>
                      <p className="text-xs font-bold text-gray-900 mt-1">{product.price.toFixed(2)} {CURRENCY}</p>
                    </div>
                  </div>
                </div>

                {/* Form Body */}
                <form onSubmit={handleSubmit} className="p-6 space-y-4">
                  
                  {/* Name Input */}
                  <div className="space-y-1">
                    <div className={`flex items-center gap-3 p-3 bg-white border ${errors.name ? 'border-red-400' : 'border-gray-200'} rounded-xl focus-within:ring-2 focus-within:ring-blue-100 transition-all`}>
                      <User size={18} className="text-gray-400" />
                      <input 
                        name="name"
                        value={formData.name}
                        onChange={handleInputChange}
                        placeholder="الاسم الكامل"
                        className="flex-1 outline-none text-right placeholder:text-gray-300"
                      />
                      <span className="text-red-500 font-bold">*</span>
                    </div>
                  </div>

                  {/* Phone Input */}
                  <div className="space-y-1">
                    <div className={`flex items-center gap-3 p-3 bg-white border ${errors.phone ? 'border-red-400' : 'border-gray-200'} rounded-xl focus-within:ring-2 focus-within:ring-blue-100 transition-all`}>
                      <Phone size={18} className="text-gray-400" />
                      <input 
                        name="phone"
                        type="tel"
                        value={formData.phone}
                        onChange={handleInputChange}
                        placeholder="رقم الهاتف"
                        className="flex-1 outline-none text-right placeholder:text-gray-300"
                      />
                      <span className="text-red-500 font-bold">*</span>
                    </div>
                  </div>

                  {/* Address Input */}
                  <div className="space-y-1">
                    <div className={`flex items-center gap-3 p-3 bg-white border ${errors.address ? 'border-red-400' : 'border-gray-200'} rounded-xl focus-within:ring-2 focus-within:ring-blue-100 transition-all`}>
                      <MapPin size={18} className="text-gray-400" />
                      <input 
                        name="address"
                        value={formData.address}
                        onChange={handleInputChange}
                        placeholder="العنوان السكني"
                        className="flex-1 outline-none text-right placeholder:text-gray-300"
                      />
                      <span className="text-red-500 font-bold">*</span>
                    </div>
                  </div>

                  {/* City Input */}
                  <div className="space-y-1">
                    <div className={`flex items-center gap-3 p-3 bg-white border ${errors.city ? 'border-red-400' : 'border-gray-200'} rounded-xl focus-within:ring-2 focus-within:ring-blue-100 transition-all`}>
                      <Building size={18} className="text-gray-400" />
                      <input 
                        name="city"
                        value={formData.city}
                        onChange={handleInputChange}
                        placeholder="المدينة"
                        className="flex-1 outline-none text-right placeholder:text-gray-300"
                      />
                      <span className="text-red-500 font-bold">*</span>
                    </div>
                  </div>

                  {/* Shipping Selection */}
                  <div className="p-3 border border-gray-200 rounded-xl bg-gray-50 flex items-center justify-between">
                    <div className="flex items-center gap-3">
                      <div className="w-5 h-5 rounded-full border-2 border-blue-600 flex items-center justify-center p-1">
                        <div className="w-full h-full bg-blue-600 rounded-full"></div>
                      </div>
                      <span className="font-medium text-gray-700">توصيل مجاني</span>
                    </div>
                    <span className="text-emerald-600 font-bold">مجاني</span>
                  </div>

                  {/* Price Summary Card */}
                  <div className="bg-gray-50 p-4 rounded-2xl space-y-2 text-sm">
                    <div className="flex justify-between text-gray-500">
                      <span>قبل المجموع:</span>
                      <span>{product.price.toFixed(2)} {CURRENCY}</span>
                    </div>
                    <div className="flex justify-between text-gray-500">
                      <span>شحن:</span>
                      <span className="text-emerald-600 font-bold">مجاني</span>
                    </div>
                    <div className="pt-2 border-t border-gray-200 flex justify-between items-center text-lg font-bold text-gray-900">
                      <span>المجموع:</span>
                      <span>{product.price.toFixed(2)} {CURRENCY}</span>
                    </div>
                  </div>

                  {/* Order Button */}
                  <button 
                    disabled={isLoading}
                    className={`w-full ${isLoading ? 'bg-blue-400' : 'bg-blue-700'} text-white py-5 rounded-2xl font-bold flex items-center justify-center gap-3 shadow-xl shadow-blue-100 transition-all hover:bg-blue-800 active:scale-[0.98] mt-4`}
                  >
                    {isLoading ? (
                      <>
                        <Loader2 className="animate-spin" />
                        جاري معالجة الطلب...
                      </>
                    ) : (
                      <>
                        <span>أكمل الطلب - {product.price.toFixed(2)} {CURRENCY}</span>
                        <ShoppingBag size={22} />
                      </>
                    )}
                  </button>
                  
                  {orderStatus === 'out-of-stock' && (
                    <div className="flex items-center gap-2 p-3 bg-red-50 text-red-600 rounded-xl text-sm border border-red-100">
                      <AlertCircle size={16} />
                      عذراً، هذا المنتج نفذ للتو من المخزن.
                    </div>
                  )}
                </form>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
};

const SuccessState = ({ onDone }) => (
  <div className="p-10 flex flex-col items-center text-center space-y-6 animate-in fade-in slide-in-from-bottom-4">
    <div className="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center">
      <CheckCircle size={48} />
    </div>
    <div className="space-y-2">
      <h2 className="text-2xl font-bold text-gray-900">شكراً لك! لقد تم استلام طلبك</h2>
      <p className="text-gray-500">سيتواصل معك فريقنا قريباً لتأكيد تفاصيل التوصيل.</p>
    </div>
    <div className="w-full bg-gray-50 rounded-2xl p-4 text-sm text-gray-600">
      رقم الطلب الخاص بك: <span className="font-mono font-bold text-blue-600">#COD-{Math.floor(Math.random() * 90000) + 10000}</span>
    </div>
    <button 
      onClick={onDone}
      className="w-full bg-gray-900 text-white py-4 rounded-xl font-bold hover:bg-black transition-colors"
    >
      العودة للمتجر
    </button>
  </div>
);

export default App;